# ============================================================
# Mission Control — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Only DATABASE_URL and NEXTAUTH_SECRET are required to start.
# ============================================================

# ── DATABASE (required) ──────────────────────────────────────

# PostgreSQL connection string
# Get from neon.tech dashboard, or railway.app, supabase.com,
# or use a local PostgreSQL instance
DATABASE_URL=

# ── AUTHENTICATION (required) ────────────────────────────────

# Secret used to sign JWT tokens
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Base URL of your app (no trailing slash)
# Use http://localhost:3000 for local development
NEXTAUTH_URL=

# Allow new users to self-register via /register
# Set to "false" to disable public registration
ALLOW_REGISTRATION=

# ── ENCRYPTION (required for integrations) ───────────────────

# 256-bit hex key used to encrypt integration API keys at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── OAUTH PROVIDERS (optional) ───────────────────────────────

# GitHub OAuth — get from github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — get from console.cloud.google.com/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI PROVIDERS (optional) ──────────────────────────────────

# Anthropic — get from console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — get from platform.openai.com/api-keys
OPENAI_API_KEY=

# Google AI — get from aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# ── INTEGRATIONS (optional) ──────────────────────────────────

# GitHub personal access token — get from github.com/settings/tokens
GITHUB_TOKEN=

# Slack incoming webhook URL — get from api.slack.com/apps
SLACK_WEBHOOK_URL=

# Vercel API token — get from vercel.com/account/tokens
VERCEL_TOKEN=

# Datadog API key — get from app.datadoghq.com/organization-settings/api-keys
DATADOG_API_KEY=

# Sentry DSN — get from sentry.io project settings
SENTRY_DSN=

# Linear API key — get from linear.app/settings/api
LINEAR_API_KEY=

# PagerDuty API key — get from pagerduty.com/api-key-access
PAGERDUTY_API_KEY=

# ── CONFIG ───────────────────────────────────────────────────

# Node environment: development | production | test
NODE_ENV=
