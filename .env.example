# ============================================================
# Mission Control — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Only DATABASE_URL and NEXTAUTH_SECRET are required.
# Everything else is optional.
# ============================================================

# ── DATABASE ──────────────────────────────────────────────────
# Any PostgreSQL provider works: Neon, Railway, Supabase, AWS RDS,
# local Docker, etc. Just provide the connection string.
# If using Docker Compose: use the default below as-is.
DATABASE_URL="postgresql://mission_control:mission_control@localhost:5432/mission_control"

# ── AUTHENTICATION ────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Allow new users to self-register (set to false to disable)
ALLOW_REGISTRATION=true

# ── ENCRYPTION ────────────────────────────────────────────────
# Used to encrypt integration credentials at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="change-me-to-a-random-hex-string"

# ── OPTIONAL: OAuth Providers ─────────────────────────────────
# Only configure the ones you want to use for login.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── OPTIONAL: AI Providers ────────────────────────────────────
# Only needed if using the AI Agents module.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=

# ── OPTIONAL: Integrations ────────────────────────────────────
# Only configure the services you want to connect.
# GITHUB_TOKEN=
# SLACK_WEBHOOK_URL=
# VERCEL_TOKEN=
# DATADOG_API_KEY=
# SENTRY_DSN=
# LINEAR_API_KEY=
# PAGERDUTY_API_KEY=

# ── CONFIG ────────────────────────────────────────────────────
NODE_ENV=development
